# ==========================================
# AS³ - AUTONOMOUS SYNTHETIC SPACE SCIENTIST
# .env.example - Copy to .env and fill in your credentials
# ==========================================

# ==================
# API Configuration
# ==================
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=False  # Set to True for development
SECRET_KEY=change-this-to-a-random-string-in-production

# ==================
# LLM Configuration (Required)
# ==================
OPENAI_API_KEY=sk-your-openai-api-key-here
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.7

# ==================
# NASA APIs (Free - Recommended)
# ==================
# Sign up at: https://api.nasa.gov
NASA_API_KEY=your-nasa-api-key-here
NASA_ISS_API_URL=https://api.nasa.gov/iss-now.json
NASA_NEO_API_URL=https://api.nasa.gov/neo/rest/v1/neo
NASA_IMAGERY_API_URL=https://api.nasa.gov/planetary/earth/imagery
NASA_APOD_API_URL=https://api.nasa.gov/planetary/apod
ENABLE_NASA_APIs=True

# ==================
# ESA/Copernicus APIs (Optional)
# ==================
# Sign up at: https://dataspace.copernicus.eu
ESA_API_KEY=your-esa-api-key-here
ESA_CLIENT_ID=your-esa-client-id
ESA_CLIENT_SECRET=your-esa-client-secret
ENABLE_ESA_APIs=True

# ==================
# NOAA Space Weather (Free - No Key Required)
# ==================
# API automatically available at: https://services.swpc.noaa.gov
NOAA_SWPC_API_URL=https://services.swpc.noaa.gov/json
NOAA_GEOMAGNET_URL=https://services.swpc.noaa.gov/json/planetary/data.json
ENABLE_NOAA_APIs=True

# ==================
# Space-Track.org TLE Data (Optional)
# ==================
# Sign up at: https://www.space-track.org (free account)
SPACETRACK_USERNAME=your-username
SPACETRACK_PASSWORD=your-password
SPACETRACK_API_URL=https://www.space-track.org/api
ENABLE_SPACETRACK=True

# ==================
# RAG Configuration
# ==================
RAG_VECTOR_DB=chroma
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=100

# ==================
# Machine Learning
# ==================
ML_ANOMALY_THRESHOLD=0.1
ML_ISOLATION_CONTAMINATION=0.1
ML_STATISTICAL_ZSCORE=3
ENABLE_ML_TRAINING=True

# ==================
# Database (PostgreSQL)
# ==================
# Local development (Docker)
DATABASE_URL=postgresql://as3user:as3password@localhost:5432/as3_db

# Or for production
# DATABASE_URL=postgresql://user:password@your-host:5432/as3_db
DATABASE_POOL_SIZE=20
DATABASE_POOL_RECYCLE=3600
DATABASE_ECHO=False

# ==================
# Redis (Optional - for caching)
# ==================
REDIS_URL=redis://localhost:6379/0
ENABLE_REDIS=False

# ==================
# Email Notifications (Optional)
# ==================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=as3-platform@example.com
ENABLE_EMAIL_ALERTS=True

# ==================
# Webhooks
# ==================
WEBHOOK_ENABLED=True
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_TIMEOUT=10

# ==================
# Logging
# ==================
LOG_LEVEL=INFO
LOG_FILE=logs/as3.log
LOG_FORMAT=json
ENABLE_STRUCTURED_LOGGING=True

# ==================
# Monitoring
# ==================
ENABLE_PROMETHEUS=True
PROMETHEUS_PORT=9090
ENABLE_GRAFANA=True
GRAFANA_PORT=3001

# ==================
# Security
# ==================
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
ENABLE_HTTPS=False  # True in production
CORS_ORIGINS=["http://localhost:3000", "http://localhost:3001"]
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# ==================
# Frontend URLs
# ==================
FRONTEND_BASE_URL=http://localhost:3000
